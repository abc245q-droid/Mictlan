  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5cc74ef59e49a8940b2c14507691cd06, type: 3}
  m_Name: Encuentro_Mictlantecuhtli
  m_EditorClassIdentifier: Assembly-CSharp::Conversation
  descripcion: Encuentro con Mictlantecuhtli a la salida de Atlein
  nodes:
  - nodeName: Apertura
    lines:
    - speaker: 
      text: "[El monolito brilla. Del aire fr\xEDo emerge una figura envuelta en
        obsidiana y luz p\xE1lida. Sus ojos son dos soles invertidos.]"
      speakerColor: {r: 0, g: 0, b: 0, a: 0}
      esAcotacion: 1
      personaje: {fileID: 0}
      expresion: 
      limpiarRetratos: 0
    - speaker: 
      text: "He esperado a alguien como t\xFA, ajolote."
      speakerColor: {r: 0, g: 0, b: 0, a: 0}
      esAcotacion: 0
      personaje: {fileID: 0}
      expresion: 
      limpiarRetratos: 0
    - speaker: Mictlantecuhtli
      text: "Aunque no entiendes qu\xE9 significan tus pasos en mi reino."
      speakerColor: {r: 0, g: 0, b: 0, a: 0}
      esAcotacion: 0
      personaje: {fileID: 11400000, guid: a6577ef44d7cc714a989818ebc87af55, type: 2}
      expresion: 
      limpiarRetratos: 0
    choices:
    - text: "\xBFQui\xE9n eres?"
      targetNode: 1
    - text: Solo quiero salir.
      targetNode: 1
    nextNode: -1
  - nodeName: Respuesta
    lines:
    - speaker: 
      text: "[Mictlantecuhtli sonr\xEDe, si es que pueden sonre\xEDr los dioses.]"
      speakerColor: {r: 0, g: 0, b: 0, a: 0}
      esAcotacion: 1
      personaje: {fileID: 0}
      expresion: 
      limpiarRetratos: 0
    - speaker: Mictlantecuhtli
      text: "La salida est\xE1 arriba. Pero deber\xE1s ser fuerte."
      speakerColor: {r: 0, g: 0, b: 0, a: 0}
      esAcotacion: 0
      personaje: {fileID: 11400000, guid: a6577ef44d7cc714a989818ebc87af55, type: 2}
      expresion: 
      limpiarRetratos: 0
    choices: []
    nextNode: -1
